    // ============================================================================
    const ACHIEVEMENT_DEFS = [
        { id: 'first_steps', icon: '👣', title: 'First Steps', desc: 'Complete your first habit', xp: 25 },
        { id: 'bookworm', icon: '📖', title: 'Bookworm', desc: 'Study for 10 hours total', xp: 50 },
        { id: 'on_fire', icon: '🔥', title: 'On Fire', desc: 'Reach a 7-day streak', xp: 50 },
