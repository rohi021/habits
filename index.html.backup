        { id: 'semester_strong', icon: '🎓', title: 'Semester Strong', desc: 'Maintain 3.5+ GPA', xp: 75 },
        { id: 'goal_getter', icon: '🎯', title: 'Goal Getter', desc: 'Complete 5 goals', xp: 75 },
        { id: 'centurion_plus', icon: '🏆', title: 'Centurion Plus', desc: 'Earn 1000 XP', xp: 50 },
        { id: 'scholar', icon: '📚', title: 'Scholar', desc: 'Reach level 20', xp: 75 },
