        { id: 'social_butterfly', icon: '🦋', title: 'Social Butterfly', desc: 'Log social mood factor 10 times', xp: 50 },
        { id: 'zen_master', icon: '🧘', title: 'Zen Master', desc: '7 days mindfulness habit', xp: 50 },
        { id: 'financial_wizard', icon: '🧙', title: 'Financial Wizard', desc: '3 months under budget', xp: 100 },
        { id: 'topic_master', icon: '📝', title: 'Topic Master', desc: 'Cover all syllabus topics for an exam', xp: 75 },
