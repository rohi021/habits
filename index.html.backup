        { id: 'milestone_maker', icon: '🏁', title: 'Milestone Maker', desc: 'Complete 10 milestones', xp: 50 },
        { id: 'organized', icon: '🗂️', title: 'Organized', desc: 'Add 5 timetable entries', xp: 50 },
        { id: 'pomodoro_pro', icon: '🍅', title: 'Pomodoro Pro', desc: 'Complete 25 Pomodoro cycles', xp: 75 },
        { id: 'word_smith', icon: '✍️', title: 'Word Smith', desc: 'Write a 500+ word journal entry', xp: 50 },
        { id: 'subject_master', icon: '🎯', title: 'Subject Master', desc: 'Create 5 custom subjects', xp: 25 },
        { id: 'water_week', icon: '🌊', title: 'Water Week', desc: 'Hit water goal 7 consecutive days', xp: 50 },
        { id: 'exam_ace', icon: '💎', title: 'Exam Ace', desc: 'Complete 5 exams', xp: 75 },
        { id: 'self_aware', icon: '🪞', title: 'Self Aware', desc: 'Log mood for 14 consecutive days', xp: 50 },
        { id: 'study_diverse', icon: '🌈', title: 'Study Diverse', desc: 'Study 3 subjects in one day', xp: 50 },
        { id: 'level_10', icon: '🔟', title: 'Double Digits', desc: 'Reach level 10', xp: 50 },
        { id: 'gratitude', icon: '🙏', title: 'Grateful Heart', desc: 'Write gratitude 7 days in a row', xp: 50 },
        { id: 'calendar_king', icon: '📅', title: 'Calendar King', desc: 'Have events on 5 different days this week', xp: 50 },
        { id: 'power_hour', icon: '⚡', title: 'Power Hour', desc: 'Study for 60 minutes without pausing', xp: 50 },
        { id: 'five_k_xp', icon: '🌟', title: '5K XP', desc: 'Earn 5000 total XP', xp: 100 },
    ];

    // ============================================================================
    // DAILY CHALLENGE POOL (50+)
    // ============================================================================
    const DAILY_CHALLENGE_POOL = [
        { text: 'Study for 1 hour', type: 'study', target: 60, xp: 15 },
        { text: 'Study for 2 hours', type: 'study', target: 120, xp: 20 },
        { text: 'Log all meals as expenses', type: 'expense', target: 3, xp: 10 },
